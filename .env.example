# ============================================================
# Variables del CLIENTE (bundle del navegador, prefijo VITE_)
# Copia este archivo como ".env" o ".env.local" y rellena los datos.
# El anon key es público por diseño: los datos los protege RLS.
# ============================================================
VITE_SUPABASE_URL=tu-url-de-supabase
VITE_SUPABASE_ANON_KEY=tu-anon-key-de-supabase

# Error tracking (opcional): crea un proyecto React en sentry.io y pega el DSN.
# Sin esta variable, Sentry no se carga (cero impacto en el bundle).
# VITE_SENTRY_DSN=https://...@...ingest.sentry.io/...

# ============================================================
# Variables del SERVIDOR (configurar en Vercel → Environment
# Variables; NUNCA con prefijo VITE_ ni commiteadas al repo).
# Usadas por /api/extract — ver docs/SECURITY.md.
# ============================================================
# SUPABASE_URL=tu-url-de-supabase
# SUPABASE_SERVICE_ROLE_KEY=service-role-key-SECRETA
# VLM_PROVIDER=gemini            # gemini | openai
# GEMINI_API_KEY=...             # si VLM_PROVIDER=gemini
# OPENAI_API_KEY=...             # si VLM_PROVIDER=openai
# AI_MONTHLY_LIMIT=300           # extracciones/mes por usuario
# AI_BURST_LIMIT=10              # extracciones/minuto por usuario
